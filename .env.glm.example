# Copy this file to .env.glm and fill in your own values.
# Environment variables from the shell still take precedence.

GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-5.1
GLM_PROXY_PORT=3827
GLM_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
GLM_MAX_TOKENS=131072
GLM_TEMPERATURE=0.2
# Optional: enable session memory (auto-compact must also be enabled in ~/.claude.json).
# In OSS builds, GrowthBook feature flags are unavailable so session memory is disabled by default.
# Set to 1 to enable session memory extraction during conversations.
# CLAUDE_SESSION_MEMORY_ENABLED=1

# Z AI Vision MCP: API key for the GLM vision MCP server (@z_ai/mcp-server).
# Required if you want to use vision tools (image analysis, OCR, UI-to-code, etc.).
Z_AI_API_KEY=your_z_ai_api_key_here

# Optional: default project directory when no directory argument is passed.
# FREE_CODE_DEFAULT_DIR=G:\Study\your-project
